{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/v2/crates/tauri-cli/schema.json",
  "productName": "Sigil Atlas",
  "version": "0.1.0",
  "identifier": "com.sigilatlas.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1522",
    "beforeDevCommand": "./build-photos.sh debug && pnpm dev",
    "beforeBuildCommand": "./build-photos.sh release && pnpm build",
    "beforeBundleCommand": "./build-photos.sh release"
  },
  "app": {
    "windows": [
      {
        "title": "Sigil Atlas",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "externalBin": ["binaries/sa-photos"],
    "macOS": {
      "signingIdentity": null,
      "minimumSystemVersion": "12.0",
      "infoPlist": "Info.plist"
    },
    "fileAssociations": [
      {
        "ext": ["sigil"],
        "name": "Sigil",
        "description": "A SigilAtlas saved view (a SigilML expression plus camera and arrangement).",
        "role": "Editor",
        "rank": "Default",
        "exportedType": {
          "identifier": "com.sigilatlas.collage",
          "conformsTo": ["com.apple.package", "public.composite-content"]
        }
      }
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
